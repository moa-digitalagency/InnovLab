# ========================================
# Flask Configuration
# ========================================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=False

# ========================================
# Database Configuration
# ========================================
# SQLite (development)
# DATABASE_URL=sqlite:///app.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/innovlab

DATABASE_URL=sqlite:///app.db

# ========================================
# Security — REQUIRED
# ========================================
# Generate a strong secret key:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-very-long-secret-key-change-in-production

# Admin credentials (DO NOT use default values in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-very-strong-password

# ========================================
# Optional: Force security checks in development
# ========================================
# ENFORCE_SECRET_KEY=True
# ENFORCE_ADMIN_CREDENTIALS=True

# ========================================
# Telegram Integration (optional)
# ========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ========================================
# Contact & Social
# ========================================
WHATSAPP_NUMBER=243860493345
CONSULTATION_URL=https://tidycal.com/moamyoneart/consultation-gratuite-15-min

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# Redis (optional, for rate limiting)
# ========================================
# REDIS_URL=redis://localhost:6379/0

# ========================================
# Testing
# ========================================
FLASK_TESTING=False
